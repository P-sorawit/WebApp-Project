@model IEnumerable<WebApp.Models.Post>

@{
    ViewData["Title"] = "All Posts";
}

<div class="container mt-4">
    <h2>Activity Feed</h2>
    <hr />

    <div class="row">
        @foreach (var post in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@post.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Host: @post.CreatedBy.Name</h6>
                        <span class="badge bg-primary">@post.Type</span>
                        
                        <p class="card-text mt-2">@post.Description</p>
                        
                        <p class="small text-muted">
                            Participants: @post.MinParticipants - @post.MaxParticipants
                        </p>

                        <a href="/Post/Details/@post.Id" class="btn btn-outline-primary">View Details</a>
                    </div>
                    <div class="card-footer text-muted">
                        Posted on @post.CreatedAt.ToString("MMM dd, yyyy")
                    </div>
                </div>
            </div>
        }
    </div>
</div>