@{
    ViewData["Title"] = "Create a New Post";
}

<div class="container mt-5 text-center">
    <h2>Ready to host an activity?</h2>
    <p>Click the button below to fill out your details.</p>
    
    <button id="makePost" class="btn btn-primary btn-lg mt-3">Create Post</button>
</div>

<div id="makePostContainer"></div>

@section Scripts {
    <script type="module">
        // Make sure this path matches exactly where makePost.js is in your wwwroot folder!
        import { haddleMakePost } from '/js/makePost.js'; 
        
        // Initialize the event listeners
        document.addEventListener("DOMContentLoaded", () => {
            haddleMakePost();
        });
    </script>
}